        self.prijzen = {
            'stadfiets': Decimal('15.00'), 'elektrisch': Decimal('25.00'),
            'helm': Decimal('3.00'), 'kinderzitje': Decimal('4.00')
        }
        self.borg = {'stadfiets': Decimal('50.00'), 'elektrisch': Decimal('100.00')}
        self.csv_bestand = 'verhuur_data.csv'
        
        self.init_csv()
