# =========================================================
# DATAKWALITEITSFUNCTIES
# =========================================================

def is_empty(value) -> bool:
    if pd.isna(value):
        return True
    return isinstance(value, str) and value.strip() == ""


def convert_to_number(value):
    if is_empty(value):
        return None

    try:
        return float(str(value).strip().replace(",", "."))
    except (ValueError, TypeError):
        return None


def add_error(
    errors: list,
    row_number,
    column: str,
    value,
    error_type: str,
    description: str,
) -> None:
    errors.append(
        {
            "Rijnummer": row_number,
            "Kolom": column,
            "Waarde": "" if pd.isna(value) else str(value),
            "Fouttype": error_type,
            "Omschrijving": description,
        }
    )


def controleer_datakwaliteit(dataframe: pd.DataFrame) -> dict:
    errors = []

    # Verplichte waarden
    for column in MANDATORY_COLUMNS:
        if column not in dataframe.columns:
            continue

        for index, value in dataframe[column].items():
            if is_empty(value):
                add_error(
                    errors,
                    index + 2,
                    column,
                    value,
                    "Lege waarde",
                    f"Het verplichte veld '{column}' mag niet leeg zijn.",
                )

    # FTE
    fte_column = "Fulltime equivalent"
    if fte_column in dataframe.columns:
        for index, value in dataframe[fte_column].items():
            if is_empty(value):
                continue

            number = convert_to_number(value)

            if number is None:
                add_error(
                    errors,
                    index + 2,
                    fte_column,
                    value,
                    "Ongeldig getal",
                    "De FTE moet een geldig getal zijn.",
                )
            elif number < 0 or number > 1:
                add_error(
                    errors,
                    index + 2,
                    fte_column,
                    value,
                    "Ongeldige FTE",
                    "De FTE moet tussen 0 en 1 liggen.",
                )

    # Arbeidsduur
    working_hours_column = "Arbeidsduur"
    if working_hours_column in dataframe.columns:
        for index, value in dataframe[working_hours_column].items():
            if is_empty(value):
                continue

            number = convert_to_number(value)

            if number is None:
                add_error(
                    errors,
                    index + 2,
                    working_hours_column,
                    value,
                    "Ongeldig getal",
                    "De arbeidsduur moet een geldig getal zijn.",
                )
            elif number <= 0 or number > 60:
                add_error(
                    errors,
                    index + 2,
                    working_hours_column,
                    value,
                    "Ongeldige arbeidsduur",
                    "De arbeidsduur moet groter zijn dan 0 en maximaal 60 uur zijn.",
                )

    # Datums
    today = pd.Timestamp.today().normalize()

    for column in ["Datum in dienst", "Geboortedatum"]:
        if column not in dataframe.columns:
            continue

        for index, value in dataframe[column].items():
            if is_empty(value):
                continue

            parsed_date = pd.to_datetime(
                value,
                errors="coerce",
                dayfirst=True,
            )

            if pd.isna(parsed_date):
                add_error(
                    errors,
                    index + 2,
                    column,
                    value,
                    "Ongeldige datum",
                    f"De waarde in '{column}' is geen geldige datum.",
                )
            elif parsed_date.normalize() > today:
                add_error(
                    errors,
                    index + 2,
                    column,
                    value,
                    "Datum in de toekomst",
                    f"De waarde in '{column}' mag niet in de toekomst liggen.",
                )

    # Datum in dienst versus geboortedatum
    if {"Datum in dienst", "Geboortedatum"}.issubset(dataframe.columns):
        for index, row in dataframe.iterrows():
            employment_date = pd.to_datetime(
                row["Datum in dienst"],
                errors="coerce",
                dayfirst=True,
            )

            birth_date = pd.to_datetime(
                row["Geboortedatum"],
                errors="coerce",
                dayfirst=True,
            )

            if pd.isna(employment_date) or pd.isna(birth_date):
                continue

            if employment_date <= birth_date:
                add_error(
                    errors,
                    index + 2,
                    "Datum in dienst",
                    row["Datum in dienst"],
                    "Onlogische datumvolgorde",
                    "Datum in dienst moet na de geboortedatum liggen.",
                )

    # Dubbele medewerkers per maand
    if {"Medewerker", "Kalendermaand/jaar"}.issubset(dataframe.columns):
        duplicate_mask = dataframe.duplicated(
            subset=["Medewerker", "Kalendermaand/jaar"],
            keep=False,
        )

        for index, row in dataframe[duplicate_mask].iterrows():
            add_error(
                errors,
                index + 2,
                "Medewerker",
                row["Medewerker"],
                "Dubbele registratie",
                (
                    "Deze medewerker komt meerdere keren voor "
                    "binnen dezelfde kalendermaand."
                ),
            )

    errors_dataframe = pd.DataFrame(
        errors,
        columns=[
            "Rijnummer",
            "Kolom",
            "Waarde",
            "Fouttype",
            "Omschrijving",
        ],
    )

    rows_with_errors = {
        error["Rijnummer"]
        for error in errors
        if isinstance(error["Rijnummer"], int)
    }

    total_records = len(dataframe)
    records_with_errors = len(rows_with_errors)

    if total_records > 0:
        score = round(
            ((total_records - records_with_errors) / total_records) * 100,
            2,
        )
    else:
        score = 0.0

    return {
        "score": score,
        "total_records": total_records,
        "total_errors": len(errors_dataframe),
        "records_with_errors": records_with_errors,
        "errors": errors_dataframe,
        "passed": len(errors_dataframe) == 0,
    }


