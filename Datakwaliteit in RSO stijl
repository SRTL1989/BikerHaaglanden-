    # -----------------------------------------------------
    # BESTANDEN
    # -----------------------------------------------------

    def select_file(self):
        file_path = filedialog.askopenfilename(
            title="Selecteer HRO-personeelsbestand",
            filetypes=[
                ("Ondersteunde bestanden", "*.csv *.xlsx *.xls"),
                ("CSV-bestand", "*.csv"),
                ("Excel-bestand", "*.xlsx *.xls"),
            ],
        )

        if not file_path:
            return

        try:
            dataframe = self.read_file(file_path)
        except Exception as exception:
            messagebox.showerror(
                "Bestand kon niet worden geopend",
                str(exception),
            )
            return

        self.selected_file_path = file_path
        self.source_dataframe = dataframe
        self.validation_results = None

        self.file_name_label.config(
            text=Path(file_path).name,
            fg=TEKST,
        )

        self.sidebar_status_label.config(
            text="Bronbestand is ingeladen",
            bg=SUCCES_LICHT,
            fg=SUCCES,
        )

        self.show_dataframe(
            tree=self.data_tree,
            dataframe=dataframe.head(100),
        )

        result = self.check_structure(dataframe)
        self.display_structure_result(result)
        self.clear_validation_results()

    def read_file(self, file_path: str) -> pd.DataFrame:
        suffix = Path(file_path).suffix.lower()

        if suffix == ".csv":
            try:
                dataframe = pd.read_csv(
                    file_path,
                    sep=None,
                    engine="python",
                    encoding="utf-8-sig",
                )
            except UnicodeDecodeError:
                dataframe = pd.read_csv(
                    file_path,
                    sep=None,
                    engine="python",
                    encoding="latin-1",
                )

        elif suffix in {".xlsx", ".xls"}:
            dataframe = pd.read_excel(file_path)

        else:
            raise ValueError(
                "Onjuist bestandsformaat. Kies een CSV- of Excelbestand."
            )

        if dataframe.empty:
            raise ValueError(
                "Het geselecteerde bestand bevat geen gegevens."
            )

        dataframe.columns = [
            str(column).strip()
            for column in dataframe.columns
        ]

        return dataframe

    # -----------------------------------------------------
    # STRUCTUURCONTROLE
    # -----------------------------------------------------

    def check_structure(self, dataframe: pd.DataFrame) -> dict:
        actual_columns = list(dataframe.columns)

        missing_columns = [
            column
            for column in EXPECTED_COLUMNS
            if column not in actual_columns
        ]

        extra_columns = [
            column
            for column in actual_columns
            if column not in EXPECTED_COLUMNS
        ]

        correct_order = actual_columns == EXPECTED_COLUMNS

        return {
            "structure_valid": (
                not missing_columns
                and not extra_columns
                and correct_order
            ),
            "missing_columns": missing_columns,
            "extra_columns": extra_columns,
            "correct_order": correct_order,
        }

    def display_structure_result(self, result: dict):
        if result["structure_valid"]:
            self.structure_status_label.config(
                text=(
                    "Structuurcontrole geslaagd. Alle verwachte kolommen "
                    "zijn aanwezig en staan in de juiste volgorde."
                ),
                fg=SUCCES,
            )

            self.validate_button.config(state="normal")
            return

        messages = ["De bestandsstructuur is niet correct."]

        if result["missing_columns"]:
            messages.append(
                "Ontbrekend: " + ", ".join(result["missing_columns"])
            )

        if result["extra_columns"]:
            messages.append(
                "Extra: " + ", ".join(result["extra_columns"])
            )

        if not result["correct_order"]:
            messages.append(
                "De kolommen staan niet in de juiste volgorde."
            )

        self.structure_status_label.config(
            text="\n".join(messages),
            fg=FOUT,
        )

        self.validate_button.config(state="disabled")

    def show_expected_columns(self):
        window = tk.Toplevel(self)
        window.title("Verwachte kolommen")
        window.geometry("540x590")
        window.configure(bg=ACHTERGROND)
        window.transient(self)

        header = tk.Frame(window, bg=RIJKS_DONKERBLAUW, height=72)
        header.pack(fill="x")
        header.pack_propagate(False)

        tk.Label(
            header,
            text="Verwachte bestandsstructuur",
            font=("Segoe UI", 16, "bold"),
            bg=RIJKS_DONKERBLAUW,
            fg=WIT,
        ).pack(
            anchor="w",
            padx=22,
            pady=22,
        )

        container = tk.Frame(
            window,
            bg=WIT,
            highlightbackground=RAND,
            highlightthickness=1,
        )
        container.pack(
            fill="both",
            expand=True,
            padx=20,
            pady=20,
        )

        tree = ttk.Treeview(
            container,
            columns=("Positie", "Kolomnaam"),
            show="headings",
        )

        tree.heading("Positie", text="Positie")
        tree.heading("Kolomnaam", text="Kolomnaam")

        tree.column("Positie", width=80, anchor="center")
        tree.column("Kolomnaam", width=380)

        for position, column in enumerate(EXPECTED_COLUMNS, start=1):
            tree.insert(
                "",
                "end",
                values=(position, column),
            )

        tree.pack(
            fill="both",
            expand=True,
            padx=12,
            pady=12,
        )

    # -----------------------------------------------------
    # VALIDATIE
    # -----------------------------------------------------

    def start_validation(self):
        if self.source_dataframe is None:
            messagebox.showwarning(
                "Geen bestand",
                "Selecteer eerst een bestand.",
            )
            return

        try:
            self.validation_results = controleer_datakwaliteit(
                self.source_dataframe
            )
        except Exception as exception:
            messagebox.showerror(
                "Validatie mislukt",
                str(exception),
            )
            return

        self.show_validation_results()
        self.notebook.select(self.results_tab)

        self.sidebar_status_label.config(
            text="Kwaliteitscontrole is uitgevoerd",
            bg=RIJKS_LICHTBLAUW,
            fg=RIJKS_DONKERBLAUW,
        )

    def show_validation_results(self):
        results = self.validation_results

        for widget in self.metrics_frame.winfo_children():
            widget.destroy()

        self.create_metric_card(
            self.metrics_frame,
            "Kwaliteitsscore",
            f"{results['score']}%",
            0,
        )
        self.create_metric_card(
            self.metrics_frame,
            "Totaal gecontroleerd",
            str(results["total_records"]),
            1,
        )
        self.create_metric_card(
            self.metrics_frame,
            "Totaal aantal fouten",
            str(results["total_errors"]),
            2,
        )
        self.create_metric_card(
            self.metrics_frame,
            "Rijen met fouten",
            str(results["records_with_errors"]),
            3,
        )

        if results["passed"]:
            self.etl_status_label.config(
                text=(
                    "ETL-status: SUCCESVOL. Het bestand voldoet aan "
                    "alle ingestelde datakwaliteitseisen."
                ),
                bg=SUCCES_LICHT,
                fg=SUCCES,
            )
        else:
            self.etl_status_label.config(
                text=(
                    "ETL-status: GEBLOKKEERD. Het bestand bevat "
                    "datakwaliteitsfouten en kan niet worden verwerkt."
                ),
                bg=FOUT_LICHT,
                fg=FOUT,
            )

        errors_dataframe = results["errors"]

        self.show_dataframe(
            tree=self.error_tree,
            dataframe=errors_dataframe,
        )

        self.export_button.config(
            state="normal" if not errors_dataframe.empty else "disabled"
        )

        if errors_dataframe.empty:
            messagebox.showinfo(
                "Kwaliteitscontrole",
                "De controle is afgerond. Er zijn geen fouten aangetroffen.",
            )
        else:
            messagebox.showwarning(
                "Kwaliteitscontrole",
                (
                    f"De controle is afgerond.\n\n"
                    f"Aantal fouten: {results['total_errors']}\n"
                    f"Rijen met fouten: {results['records_with_errors']}"
                ),
            )

    # -----------------------------------------------------
    # DATA TONEN
    # -----------------------------------------------------

    def show_dataframe(self, tree: ttk.Treeview, dataframe: pd.DataFrame):
        tree.delete(*tree.get_children())

        columns = list(dataframe.columns)
        tree["columns"] = columns

        for column in columns:
            tree.heading(column, text=column)

            if column == "Omschrijving":
                width = 430
            elif column == "Waarde":
                width = 185
            else:
                width = 145

            tree.column(
                column,
                width=width,
                minwidth=80,
                anchor="w",
                stretch=False,
            )

        for _, row in dataframe.iterrows():
            values = [
                "" if pd.isna(value) else str(value)
                for value in row
            ]

            tree.insert(
                "",
                "end",
                values=values,
            )

    # -----------------------------------------------------
    # EXPORT
    # -----------------------------------------------------

    def export_error_log(self):
        if self.validation_results is None:
            return

        errors_dataframe = self.validation_results["errors"]

        if errors_dataframe.empty:
            messagebox.showinfo(
                "Geen fouten",
                "Er zijn geen fouten om te exporteren.",
            )
            return

        output_path = filedialog.asksaveasfilename(
            title="Foutenlogboek opslaan",
            defaultextension=".csv",
            filetypes=[
                ("CSV-bestand", "*.csv"),
                ("Excel-bestand", "*.xlsx"),
            ],
            initialfile="etl_foutenlogboek.csv",
        )

        if not output_path:
            return

        try:
            suffix = Path(output_path).suffix.lower()

            if suffix == ".xlsx":
                errors_dataframe.to_excel(
                    output_path,
                    index=False,
                )
            else:
                errors_dataframe.to_csv(
                    output_path,
                    index=False,
                    encoding="utf-8-sig",
                )

            messagebox.showinfo(
                "Export geslaagd",
                f"Het foutenlogboek is opgeslagen:\n\n{output_path}",
            )

        except Exception as exception:
            messagebox.showerror(
                "Export mislukt",
                str(exception),
            )

    # -----------------------------------------------------
    # RESET / UITLOGGEN
    # -----------------------------------------------------

    def clear_validation_results(self):
        self.validation_results = None

        for widget in self.metrics_frame.winfo_children():
            widget.destroy()

        self.create_metric_card(self.metrics_frame, "Kwaliteitsscore", "-", 0)
        self.create_metric_card(self.metrics_frame, "Totaal gecontroleerd", "-", 1)
        self.create_metric_card(self.metrics_frame, "Totaal aantal fouten", "-", 2)
        self.create_metric_card(self.metrics_frame, "Rijen met fouten", "-", 3)

        self.etl_status_label.config(
            text="De kwaliteitscontrole is nog niet uitgevoerd.",
            bg=RIJKS_LICHTBLAUW,
            fg=RIJKS_DONKERBLAUW,
        )

        self.error_tree.delete(*self.error_tree.get_children())
        self.error_tree["columns"] = ()
        self.export_button.config(state="disabled")

    def reset_application(self):
        self.source_dataframe = None
        self.validation_results = None
        self.selected_file_path = None

        self.file_name_label.config(
            text="Geen bestand geselecteerd",
            fg=SUBTEKST,
        )

        self.sidebar_status_label.config(
            text="Nog geen bestand ingeladen",
            bg=WAARSCHUWING_LICHT,
            fg=SUBTEKST,
        )

        self.structure_status_label.config(
            text="Selecteer een CSV- of Excelbestand.",
            fg=SUBTEKST,
        )

        self.validate_button.config(state="disabled")

        self.data_tree.delete(*self.data_tree.get_children())
        self.data_tree["columns"] = ()

        self.clear_validation_results()
        self.notebook.select(self.data_tab)

    def logout(self):
        confirm = messagebox.askyesno(
            "Uitloggen",
            "Weet je zeker dat je wilt uitloggen?",
        )

        if confirm:
            self.source_dataframe = None
            self.validation_results = None
            self.selected_file_path = None
            self.show_login_screen()


