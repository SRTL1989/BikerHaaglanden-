import io
from pathlib import Path

import pandas as pd
import streamlit as st




# ---------------------------------------------------------
# PAGINACONFIGURATIE
# ---------------------------------------------------------

st.set_page_config(
    page_title="Datakwaliteit Monitor — ETL",
    page_icon="📥",
    layout="wide",
)


# ---------------------------------------------------------
# SESSION STATE
# ---------------------------------------------------------

if "logged_in" not in st.session_state:
    st.session_state.logged_in = False

if "source_dataframe" not in st.session_state:
    st.session_state.source_dataframe = None

if "validation_results" not in st.session_state:
    st.session_state.validation_results = None

if "uploaded_file_name" not in st.session_state:
    st.session_state.uploaded_file_name = None


# ---------------------------------------------------------
# VERWACHTE KOLOMMEN
# ---------------------------------------------------------

EXPECTED_COLUMNS = [
    "Organisatie",
    "Organisatie_Naam",
    "Formatieplaats",
    "Functienaam",
    "Fulltime equivalent",
    "Vakkennis",
    "Medewerker",
    "Datum in dienst",
    "Geboortedatum",
    "Geslacht",
    "Contractsoort",
    "Arbeidsduur",
    "Kalendermaand/jaar",
    "Test",
]


# ---------------------------------------------------------
# BESTAND INLEZEN
# ---------------------------------------------------------

@st.cache_data(show_spinner=False)
def read_and_validate_structure(
    file_name: str,
    file_bytes: bytes,
) -> pd.DataFrame:
    """
    Leest een CSV- of Excelbestand in.

    De kolomnamen worden opgeschoond, maar niet automatisch hernoemd.
    Hierdoor kan de applicatie daadwerkelijk controleren of de
    aangeleverde kolommen correct zijn.
    """

    suffix = Path(file_name).suffix.lower()

    if suffix == ".csv":
        dataframe = pd.read_csv(
            io.BytesIO(file_bytes),
            sep=None,
            engine="python",
        )

    elif suffix in {".xlsx", ".xls"}:
        dataframe = pd.read_excel(
            io.BytesIO(file_bytes)
        )

    else:
        raise ValueError(
            "Onjuist formaat. Lever een CSV- of Excelbestand aan."
        )

    dataframe.columns = [
        str(column).strip()
        for column in dataframe.columns
    ]

    return dataframe


# ---------------------------------------------------------
# STRUCTUURCONTROLE
# ---------------------------------------------------------

def controleer_structuur(dataframe: pd.DataFrame) -> dict:
    """
    Vergelijkt de kolommen van het bestand met de verwachte kolommen.
    """

    werkelijke_kolommen = list(dataframe.columns)

    ontbrekende_kolommen = [
        column
        for column in EXPECTED_COLUMNS
        if column not in werkelijke_kolommen
    ]

    extra_kolommen = [
        column
        for column in werkelijke_kolommen
        if column not in EXPECTED_COLUMNS
    ]

    juiste_volgorde = werkelijke_kolommen == EXPECTED_COLUMNS

    structuur_correct = (
        not ontbrekende_kolommen
        and not extra_kolommen
        and juiste_volgorde
    )

    return {
        "structuur_correct": structuur_correct,
        "ontbrekende_kolommen": ontbrekende_kolommen,
        "extra_kolommen": extra_kolommen,
        "juiste_volgorde": juiste_volgorde,
    }


def toon_structuurcontrole(structuur_resultaat: dict) -> None:
    """
    Toont de resultaten van de structuurcontrole.
    """

    if structuur_resultaat["structuur_correct"]:
        st.success(
            "✅ Structuurcontrole geslaagd. Alle verwachte kolommen "
            "zijn aanwezig en staan in de juiste volgorde."
        )
        return

    st.warning(
        "⚠️ De structuur van het bestand wijkt af van de verwachte structuur."
    )

    if structuur_resultaat["ontbrekende_kolommen"]:
        st.error(
            "Ontbrekende kolommen: "
            + ", ".join(
                structuur_resultaat["ontbrekende_kolommen"]
            )
        )

    if structuur_resultaat["extra_kolommen"]:
        st.warning(
            "Onverwachte extra kolommen: "
            + ", ".join(
                structuur_resultaat["extra_kolommen"]
            )
        )

    if not structuur_resultaat["juiste_volgorde"]:
        st.info(
            "De kolommen staan niet in de voorgeschreven volgorde."
        )


# ---------------------------------------------------------
# RESULTATEN KWALITEITSCONTROLE
# ---------------------------------------------------------

def toon_validatieresultaten() -> None:
    """
    Toont de resultaten direct op het hoofdscherm.
    """

    resultaten = st.session_state.validation_results

    if resultaten is None:
        return

    st.divider()

    st.header("📊 Resultaten kwaliteitscontrole")

    errors_df = resultaten["errors"]

    col1, col2, col3, col4 = st.columns(4)

    col1.metric(
        "Kwaliteitsscore",
        f"{resultaten['score']}%",
    )

    col2.metric(
        "Totaal gecontroleerd",
        f"{resultaten['total_records']} rijen",
    )

    col3.metric(
        "Totaal aantal fouten",
        len(errors_df),
    )

    col4.metric(
        "Rijen met fouten",
        resultaten["records_with_errors"],
    )

    if resultaten["score"] < 100:
        st.error(
            "🚨 ETL-status: GEBLOKKEERD. Het bestand bevat "
            "datakwaliteitsfouten en kan nog niet worden verwerkt."
        )
    else:
        st.success(
            "✅ ETL-status: SUCCESVOL. Het bestand voldoet aan "
            "alle ingestelde datakwaliteitseisen."
        )

    tab1, tab2 = st.tabs(
        [
            "❌ Gedetailleerd foutenlogboek",
            "📄 Volledige brondata",
        ]
    )

    with tab1:
        st.subheader("Gedetailleerd foutenlogboek")

        if errors_df.empty:
            st.success(
                "Er zijn geen inhoudelijke fouten aangetroffen."
            )

        else:
            st.dataframe(
                errors_df,
                use_container_width=True,
                hide_index=True,
            )

            csv_data = errors_df.to_csv(
                index=False
            ).encode("utf-8-sig")

            st.download_button(
                label="Download foutenlogboek als CSV",
                data=csv_data,
                file_name="etl_foutenlogboek.csv",
                mime="text/csv",
                use_container_width=True,
            )

    with tab2:
        st.subheader("Volledige ingeladen brondata")

        st.dataframe(
            st.session_state.source_dataframe,
            use_container_width=True,
            hide_index=True,
        )


